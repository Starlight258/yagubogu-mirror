# MySQL
# When MySQL is published on the Mac mini host, backend containers can reach it through host.docker.internal.
DB_URL="jdbc:mysql://host.docker.internal:3306/yagubogu?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8"
DB_USERNAME=yagubogu
DB_PASSWORD=change-me

# OAuth
GOOGLE_CLIENT_ID=change-me.apps.googleusercontent.com
APPLE_CLIENT_ID=change-me

# JWT
# Use long random secrets. Do not reuse production secrets for local performance testing.
ACCESS_TOKEN_SECRET_KEY=change-me-to-a-long-random-access-token-secret
REFRESH_TOKEN_SECRET_KEY=change-me-to-a-long-random-refresh-token-secret

# Cloudflare R2 / S3-compatible storage
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_S3_BUCKET=yagubogu

# Required only when testing image upload/presign endpoints.
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
