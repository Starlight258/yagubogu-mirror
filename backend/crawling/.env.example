# Spring
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=9000

# MySQL
# Local MySQL example:
# DB_URL="jdbc:mysql://localhost:3306/yagubogu?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8"
#
# Docker container -> Mac host MySQL example:
# DB_URL="jdbc:mysql://host.docker.internal:3306/yagubogu?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8"
DB_URL="jdbc:mysql://localhost:3306/yagubogu?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8"
DB_USERNAME=yagubogu
DB_PASSWORD=change-me

# KBO crawler settings are defined in crawling/src/main/resources/application.yml.
