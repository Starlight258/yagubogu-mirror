# --- Build stage ---
FROM amazoncorretto:21 AS build
WORKDIR /workspace

# 빌드 컨텍스트는 backend/ (Gradle 루트)
COPY gradlew gradlew
COPY gradle gradle
COPY settings.gradle ./
COPY build.gradle ./

# 멀티 모듈 build.gradle 복사
COPY app/build.gradle app/build.gradle
COPY crawling/build.gradle crawling/build.gradle

RUN sed -i 's/\r$//' gradlew && chmod +x gradlew
RUN ./gradlew --no-daemon dependencies || true

# crawling 모듈은 app 모듈 의존성이 있어 둘 다 복사
COPY app/src app/src
COPY crawling/src crawling/src

# crawling 서브모듈만 빌드
RUN ./gradlew :crawling:bootJar --no-daemon --build-cache -x test

# --- Run stage ---
FROM mcr.microsoft.com/playwright/java:v1.40.0-jammy

RUN apt-get update \
    && apt-get install -y --no-install-recommends openjdk-21-jre-headless \
    && rm -rf /var/lib/apt/lists/*

ENV TZ=Asia/Seoul
ENV JAVA_OPTS="-XX:MaxRAMPercentage=75 -XX:+UseG1GC"
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk-arm64
ENV PATH="$JAVA_HOME/bin:$PATH"
ENV SPRING_PROFILES_ACTIVE=dev
ENV PLAYWRIGHT_HEADLESS=true
ENV PLAYWRIGHT_SLOW_MO=0

WORKDIR /app

COPY --from=build /workspace/crawling/build/libs/*.jar /app/app.jar

ENTRYPOINT ["sh","-c","java $JAVA_OPTS -jar /app/app.jar"]
